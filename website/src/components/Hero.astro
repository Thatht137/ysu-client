---
import { Download, Code } from 'lucide-react';
import InlineIcon from './InlineIcon.astro';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);
---

<section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:justify-between lg:gap-16">
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left max-w-xl">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          {t.hero.title}
        </h1>
        <p class="mt-4 text-lg text-muted-foreground sm:text-xl">
          {t.hero.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
          <a
            href="#download"
            class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:scale-105 hover:shadow-xl hover:shadow-primary/30"
          >
            <Download className="w-4 h-4" />
            {t.hero.download}
          </a>
          <a
            href="https://github.com/Youwenqwq/ysu-client"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-border bg-card px-6 py-3 text-sm font-medium text-card-foreground transition-all hover:bg-muted"
          >
            <Code className="w-4 h-4" />
            {t.hero.github}
          </a>
        </div>
      </div>

      <div class="relative hidden lg:block flex-shrink-0 h-56 w-56 sm:h-72 sm:w-72 lg:h-80 lg:w-80 rounded-[22%] overflow-hidden shadow-xl dark:shadow-white/10">
        <div class="absolute -inset-8 -z-10 rounded-full bg-primary/10 blur-3xl" />
        <InlineIcon />
      </div>
    </div>
  </div>
</section>
