---
import { Lock } from 'lucide-react';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);
---

<section class="px-4 py-12 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl mb-8">
      {t.privacy.dataSource.title}
    </h2>
    <p class="text-center text-muted-foreground leading-relaxed max-w-xl mx-auto">
      {t.privacy.dataSource.content}
    </p>
  </div>
</section>
