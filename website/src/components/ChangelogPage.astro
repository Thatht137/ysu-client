---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { ArrowLeft } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';

const locale = Astro.currentLocale ?? 'zh';
const t = await import(`../i18n/${locale}.json`).then(m => m.default);
const changelog = await import('../data/changelog.json').then(m => m.default);

const homeUrl = getRelativeLocaleUrl(locale, '/');
---

<Layout title={`${t.changelog.title} - ${t.appName}`}>
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <a
      href={homeUrl}
      class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
    >
      <ArrowLeft className="w-4 h-4" />
      {t.changelog.back}
    </a>
    <h1 class="text-3xl font-bold">{t.changelog.title}</h1>
    <div class="mt-8 space-y-8">
      {changelog.map(item => (
        <div class="rounded-2xl border border-border bg-card p-6">
          <div class="flex items-center gap-3">
            <span class="text-xl font-bold">v{item.version}</span>
            <span class="text-sm text-muted-foreground">{item.date}</span>
          </div>
          <div class="changelog-body mt-4 text-sm leading-relaxed" set:html={marked.parse(item.body || item.changes?.join('\n') || '')} />
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .changelog-body :global(h2) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-foreground);
  }
  .changelog-body :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 0.75rem;
    margin-bottom: 0.375rem;
    color: var(--color-foreground);
  }
  .changelog-body :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .changelog-body :global(li) {
    margin-bottom: 0.25rem;
  }
  .changelog-body :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }
  .changelog-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .changelog-body :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.875em;
    background: var(--color-muted);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
  .changelog-body :global(p) {
    margin-bottom: 0.5rem;
  }
</style>
